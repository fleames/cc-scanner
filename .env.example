# URL of your Indexaro instance (no trailing slash)
INDEXARO_URL=https://indexaro.com

# Shared secret — must match CC_INTERNAL_SECRET on the Indexaro server
CC_INTERNAL_SECRET=change-me-to-a-long-random-string

# Optional: Open PageRank API key (free at https://openpagerank.com)
# Leave blank to skip PageRank enrichment
OPR_API_KEY=

# How many referring domains to send per target domain (default: 100)
# Higher = more storage used on Indexaro, lower = less detail
TOP_DOMAINS_LIMIT=100

# Cron schedule for checking new CC releases (default: weekly on Monday 04:00)
# The scanner checks if a new release exists and skips if already processed.
CRON_SCHEDULE=0 4 * * 1

# Optional: local temp directory for processing (default: /tmp/cc-scanner)
TEMP_DIR=/tmp/cc-scanner
